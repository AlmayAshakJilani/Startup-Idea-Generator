<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Startup Idea Generator</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: #e5e7eb;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .container {
      background: #020617;
      padding: 25px;
      border-radius: 12px;
      width: 90%;
      max-width: 400px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.6);
    }

    h1 {
      font-size: 22px;
      margin-bottom: 10px;
      color: #38bdf8;
    }

    p {
      font-size: 14px;
      color: #94a3b8;
    }

    .idea-box {
      margin: 20px 0;
      padding: 15px;
      background: #020617;
      border: 1px solid #1e293b;
      border-radius: 8px;
      min-height: 80px;
      font-size: 15px;
    }

    button {
      background: #38bdf8;
      border: none;
      padding: 12px 18px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: bold;
      cursor: pointer;
      color: #020617;
    }

    button:hover {
      background: #0ea5e9;
    }

    footer {
      margin-top: 15px;
      font-size: 12px;
      color: #64748b;
    }
  </style>
</head>
<body>

<div class="container">
  <h1>🚀 Startup Idea Generator</h1>
  <p>Click the button to get a random startup idea</p>

  <div class="idea-box" id="idea">
    Your startup idea will appear here...
  </div>

  <button onclick="generateIdea()">Generate Idea</button>

  <footer>
    Built by Elme Ashek Zilani
  </footer>
</div>

<script>
  const ideas = [
    "AI-powered study planner for students",
    "Smart farming system using IoT sensors",
    "Local service marketplace for small towns",
    "Mental health journaling app with AI insights",
    "Affordable robotics kits for school students",
    "Skill-based micro job platform for students",
    "AI resume & CV improvement tool",
    "Smart energy monitoring system for homes",
    "Online tutoring platform for rural areas",
    "Fitness app with daily habit tracking",
    "AI-powered note summarizer for students",
    "Smart waste management system for cities",
    "Freelancer portfolio builder with AI",
    "Language learning app using voice AI",
    "Remote team productivity analytics tool"
  ];

  function generateIdea() {
    const randomIndex = Math.floor(Math.random() * ideas.length);
    document.getElementById("idea").innerText = ideas[randomIndex];
  }
</script>

</body>
</html>